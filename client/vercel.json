{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://finlearn-1.onrender.com/:path*"
    },
    {
      "source": "/admin.html",
      "destination": "/admin.html"
    },
    {
      "source": "/((?!assets/|admin\\.html).*)",
      "destination": "/index.html"
    }
  ]
}